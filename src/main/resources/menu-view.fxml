<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="825.0" prefWidth="1193.0" styleClass="menu-root"
            xmlns="http://javafx.com" xmlns:fx="http://javafx.com" 
            fx:controller="fr.quentincillierre.hangman.controller.MenuController">
   <children>

      <!-- CENTER PANEL COLLECTION: Primary Layout Context Interface Blocks -->
      <VBox alignment="CENTER" spacing="25.0" prefHeight="825.0" prefWidth="1193.0">
         <children>
            <!-- Title -->
            <Label fx:id="menuTitleLabel" text="HANGMAN ADVENTURE">
               <font>
                  <Font name="Arial Bold" size="48.0" />
               </font>
               <effect>
                  <DropShadow color="#00000099" radius="8.0" />
               </effect>
            </Label>

            <!-- Subtitle -->
            <Label fx:id="subtitleLabel" text="CAN YOU SAVE YOURSELF IN TIME?">
               <font>
                  <Font name="Arial Italic" size="18.0" />
               </font>
            </Label>

            <!-- Selection Configuration Settings -->
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <VBox alignment="CENTER_LEFT" spacing="5.0">
                     <children>
                        <Label fx:id="categoryLabel" text="Select Category:"/>
                        <ComboBox fx:id="categoryBox" prefWidth="180.0" promptText="Words A - G" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER_LEFT" spacing="5.0">
                     <children>
                        <Label fx:id="difficultyLabel" text="Select Difficulty:"/>
                        <ComboBox fx:id="difficultyBox" prefWidth="150.0" promptText="Medium" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <!-- Local High-Scores Dashboard Display Card -->
            <VBox fx:id="highScoresCard" alignment="CENTER" spacing="8.0" maxWidth="450.0">
               <children>
                  <Label fx:id="highScoresTitleLabel" text="🏆 TOP LOCAL RUN RECORDS"/>
                  <Label fx:id="highScoresLabel" text="No scores recorded yet" textAlignment="CENTER"/>
               </children>
            </VBox>

            <!-- Menu Navigation Actions -->
            <VBox alignment="CENTER" spacing="15.0">
               <children>
                  <Button fx:id="startButton" minWidth="200.0" prefHeight="45.0" text="START GAME" onAction="#handleStartGame"/>
                  <Button fx:id="exitButton" minWidth="200.0" prefHeight="45.0" text="EXIT" onAction="#handleExitGame"/>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>