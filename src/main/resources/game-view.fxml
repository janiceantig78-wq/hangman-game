<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="825.0" prefWidth="1193.0" styleClass="game-root"
            xmlns="http://javafx.com" xmlns:fx="http://javafx.com"
            fx:controller="fr.quentincillierre.hangman.controller.GameController">
   <children>
      <!-- Top Action Controls Header Area -->
      <Button fx:id="resetButton" layoutX="50.0" layoutY="30.0" onAction="#resetGame" text="🔄 Reset Game" />
<Button fx:id="backMenuButton" layoutX="175.0" layoutY="30.0" onAction="#handleBackToMenu" text="🔙 Back to Menu" />
<Button fx:id="hintButton" layoutX="315.0" layoutY="30.0" onAction="#handleTriggerHint" text="💡 Use Hint (-30 pts)" />

<Label fx:id="timerLabel" layoutX="880.0" layoutY="35.0" text="Time: 60s" />
<Label fx:id="pointsLabel" layoutX="1010.0" layoutY="35.0" text="Points: 100" />

      <!-- Centered Structural Information Labels -->
      <Label fx:id="titleLabel" layoutX="475.0" layoutY="26.0" text="GUESS THE WORD!" textFill="#220d75">
         <font>
            <Font name="System Bold" size="30.0" />
         </font>
      </Label>

      <Label fx:id="wrongLabel" layoutX="264.0" layoutY="90.0" prefWidth="665.0" text="Category: Loading..." alignment="CENTER">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
      </Label>

      <Label fx:id="wordLabel" layoutX="264.0" layoutY="140.0" prefWidth="665.0" text="_ _ _ _ _ _ _ _" alignment="CENTER">
         <font>
            <Font name="System Bold" size="36.0" />
         </font>
      </Label>

      <!-- Center Aligned Horizontal Box to Center the Gallows Drawing Perfectly -->
<HBox layoutX="0.0" layoutY="230.0" prefWidth="1193.0" alignment="CENTER">
   <children>
      <HBox fx:id="hangmanBox" alignment="CENTER" styleClass="hangman-box">
         <children>
            <ImageView fx:id="hangmanView" fitHeight="290.0" fitWidth="460.0" preserveRatio="true" />
         </children>
      </HBox>
   </children>
</HBox>

      <!-- End-Game Hidden Target Display Label -->
      <Label fx:id="correctWordLabel" layoutX="264.0" layoutY="565.0" prefWidth="665.0" alignment="CENTER" text="">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>

      <!-- Bottom Interactive Alphabet Input Entry Grid -->
      <GridPane fx:id="keyboardGrid" layoutX="70.0" layoutY="620.0" prefHeight="120.0" prefWidth="1034.0" hgap="8.0" vgap="8.0" />
   </children>
</AnchorPane>
