<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.Blend?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
    fx:controller="fr.quentincillierre.hangman.controller.GameController"
    maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="825.0" prefWidth="1193.0"
    xmlns="http://javafx.com/javafx/26">

    <children>
        <!-- Title Label -->
        <Label fx:id="titleLabel" layoutX="264.0" layoutY="20.0" prefHeight="40.0" prefWidth="1193.0"
            text="GUESS THE WORD!" textAlignment="CENTER" textFill="#220d75" wrapText="true"
            AnchorPane.leftAnchor="264.0" AnchorPane.rightAnchor="-264.0" AnchorPane.topAnchor="26.0">
            <font>
                <Font name="Arial Bold" size="37.0" />
            </font>
            <effect>
                <Blend />
            </effect>
        </Label>

        <!-- Reset Button -->
        <Button fx:id="resetButton" layoutX="50" layoutY="100" text="Reset Game" onAction="#resetGame"/>

        <!-- Word Label -->
        <Label fx:id="wordLabel" layoutX="304.0" layoutY="66.0" prefHeight="66.0" prefWidth="201.0"
            text="_ _ _ _ _ _ _ _"
            AnchorPane.leftAnchor="304.0" AnchorPane.rightAnchor="-264.0" AnchorPane.topAnchor="66.0">
            <font>
                <Font size="24.0" />
            </font>
        </Label>

        <!-- Hangman Image -->
        <ImageView fx:id="hangmanView" fitHeight="338.0" fitWidth="540.0" layoutX="246.0" layoutY="217.0"
            preserveRatio="true"
            AnchorPane.bottomAnchor="270.0" AnchorPane.topAnchor="217.0" />

        <!-- Result Label -->
        <Label fx:id="resultLabel" layoutX="330.0" layoutY="619.0" prefHeight="30.0" prefWidth="849.0"
            AnchorPane.leftAnchor="330.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="619.0">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>

        <!-- Keyboard Grid -->
        <GridPane fx:id="keyboardGrid" layoutX="70.0" layoutY="696.0" prefHeight="60.0" prefWidth="1034.0"
            hgap="8.0" vgap="8.0"
            AnchorPane.leftAnchor="70.0" AnchorPane.rightAnchor="89.0" AnchorPane.topAnchor="696.0">
            <columnConstraints>
                <!-- 13 columns -->
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints maxHeight="40.0" minHeight="10.0" prefHeight="26.0" vgrow="SOMETIMES" />
                <RowConstraints maxHeight="39.0" minHeight="10.0" prefHeight="34.0" vgrow="SOMETIMES" />
            </rowConstraints>
        </GridPane>
    </children>

    <cursor>
        <Cursor fx:constant="CROSSHAIR" />
    </cursor>
    <effect>
        <DropShadow />
    </effect>
</AnchorPane>